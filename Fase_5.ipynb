cu1_grade     = float(input("Nota promedio 1er sem            [0-20, ej: 13.5]: "))

# ── ACADÉMICOS 2do semestre ──────────────────────────────────
cu2_enrolled  = float(input("Unidades 2do sem (matriculadas)  [ej: 6]: "))
